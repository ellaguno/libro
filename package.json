{
  "name": "sesolibre-libro",
  "version": "1.0.0",
  "description": "Visor de PDF tipo libro/revista (flipbook) para hosting compartido — PHP + TypeScript",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "serve": "php -S localhost:8080 -t public"
  },
  "devDependencies": {
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "pdfjs-dist": "^4.5.136"
  }
}
